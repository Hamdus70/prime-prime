rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserProfile(uid) {
      return get(/databases/$(database)/documents/user_profiles/$(uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
             getUserProfile(request.auth.uid).role == role;
    }
    
    function isStaffOrAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
             (getUserProfile(request.auth.uid).role == 'staff' || getUserProfile(request.auth.uid).role == 'admin');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profiles ---
    match /user_profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaffOrAdmin());
      // Special: allow unauthenticated get for login email lookup (risky but needed for custom ID login)
      // Restricted to just fetching by ID
      allow get: if !isSignedIn(); 
      allow list: if hasRole('admin');
      allow create: if true; // Support registration/auto-approve
      allow update: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
    }

    // --- Credentials ---
    match /credentials/{username} {
      allow get: if true; // Needed for System ID lookup
      allow create: if true; // Needed for registration
      allow update: if isSignedIn() && (getUserProfile(request.auth.uid).username == username || hasRole('admin'));
    }

    // --- Counters ---
    match /counters/{counterId} {
      allow get, update, create: if true; // Needed for unique clinical ID generation on client
    }

    // --- Patients ---
    match /patients/{patientId} {
      function canAccessPatient() {
        let isOwner = resource.data.userId == request.auth.uid;
        let isAdminMember = hasRole('admin');
        let isStaffMember = isStaffOrAdmin() && request.auth.uid in get(/databases/$(database)/documents/patients/$(patientId)).data.assignedStaff;
        return isOwner || isAdminMember || isStaffMember;
      }

      allow get: if isSignedIn() && canAccessPatient();
      allow list: if isSignedIn(); // Filtered by query
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (hasRole('admin') || canAccessPatient());

      // Clinical workflows
      match /vitals/{vitalId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
      }

      match /care_plans/{planId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
        allow update: if isStaffOrAdmin(); 
      }

      match /drug_charts/{chartId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin(); // Doctors only for prescription logic checked in UI, for now base staff
        allow update: if isStaffOrAdmin();
      }

      match /intake_output/{ioId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
      }

      match /nursing_reports/{reportId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
      }

      match /clinical_notes/{noteId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
        allow update: if isStaffOrAdmin() && (resource.data.staffId == request.auth.uid || hasRole('admin'));
      }

      match /investigations/{invId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
        allow update: if isStaffOrAdmin();
      }

      match /encounters/{encounterId} {
        allow read: if isSignedIn() && canAccessPatient();
        allow create: if isStaffOrAdmin();
      }
    }

    // --- Pharmacy & Inventory ---
    match /pharmacy_orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin();
    }

    // --- Laboratory Requests ---
    match /lab_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin();
    }

    // --- Radiology Requests ---
    match /radiology_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isStaffOrAdmin();
    }

    // --- Surgery ---
    match /surgical_cases/{caseId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isStaffOrAdmin());
      allow write: if isStaffOrAdmin();

      match /preop_checklist/{id} { allow read, write: if isStaffOrAdmin(); }
      match /intraop_record/{id} { allow read, write: if isStaffOrAdmin(); }
      match /postop_monitoring/{id} { allow read, write: if isStaffOrAdmin(); }
    }

    match /theatre_schedule/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isStaffOrAdmin();
    }

    // --- Laboratory Results (Subcollection) ---
    match /patients/{patientId}/lab_results/{resultId} {
      allow read: if isSignedIn() && (patientId == request.auth.uid || isStaffOrAdmin());
      allow write: if isStaffOrAdmin();
    }

    // --- Global Alerts ---
    match /alerts/{alertId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isStaffOrAdmin());
      allow create: if isSignedIn(); // Allow system or staff to create
      allow update: if isStaffOrAdmin();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || hasRole('admin'));
      allow write: if hasRole('admin');
    }

    // --- Complaints ---
    match /complaints/{complaintId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isStaffOrAdmin());
      allow update: if hasRole('admin');
    }

    // --- Applications ---
    match /applications/{appId} {
      allow create: if true;
      allow get: if true;
      allow read: if (resource.data.trackingToken != null && request.query.limit <= 10) || hasRole('admin');
      allow update: if hasRole('admin') || 
                   (resource.data.status == 'unverified') || 
                   (resource.data.trackingToken != null);
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow create: if true;
      allow read, update: if hasRole('admin');
    }

    // --- OTP Logs ---
    match /otp_logs/{otpId} {
      allow create: if true;
      allow read: if hasRole('admin');
    }

    // --- Assessments ---
    match /patient_assessments/{assessmentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isStaffOrAdmin());
    }

    // --- Attendance ---
    match /attendance/{recordId} {
      allow read: if hasRole('admin') || (isSignedIn() && resource.data.staffId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.staffId == request.auth.uid;
      allow update: if hasRole('admin') || (isSignedIn() && resource.data.staffId == request.auth.uid);
    }

    // --- Announcements ---
    match /announcements/{annId} {
      allow read: if isSignedIn() && (
        resource.data.target == 'global' || 
        (resource.data.target == 'staff' && isStaffOrAdmin()) ||
        (resource.data.target == 'patient' && !isStaffOrAdmin()) ||
        (resource.data.target == 'targeted' && request.auth.uid in resource.data.targetIds)
      );
      allow write: if hasRole('admin');
    }

    // --- Recovery Codes ---
    match /recovery_codes/{email} {
      allow read, write: if true; // Needed for recovery flow
    }

    // --- Obs & Gynae ---
    function isValidOGCase(data) {
      return data.patientName is string && data.patientName.size() <= 200 &&
             data.patientId is string && data.patientId.size() <= 100 &&
             data.unit in ['Antenatal', 'Labour', 'Postnatal', 'Gynae', 'Fertility'] &&
             data.status in ['Active', 'Completed', 'Archived'];
    }

    match /og_cases/{caseId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin() && isValidOGCase(request.resource.data);
      allow update: if isStaffOrAdmin() && isValidOGCase(request.resource.data);
      allow delete: if hasRole('admin');
    }

    // --- Audit Logs ---
    match /audit_logs/{logId} {
      allow read, create: if hasRole('admin');
    }
    
    // Connectivity test
    match /test/connection {
      allow get: if true;
    }
  }
}
